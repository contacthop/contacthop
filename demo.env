# ContactHop configuration — copy to .env and adjust:  cp demo.env .env
# Every setting is read from the environment with the CONTACTHOP_ prefix.
# Defaults shown commented out; uncomment to change.

# ── Database ────────────────────────────────────────────────────────────────
# Any async SQLAlchemy URL. SQLite needs nothing; production wants Postgres.
#CONTACTHOP_DATABASE_URL=sqlite+aiosqlite:///contacthop.db
#CONTACTHOP_DATABASE_URL=postgresql+asyncpg://contacthop:secret@localhost/contacthop

# Create missing tables at startup — handy in dev, off in production where
# the schema is managed by `contacthop migrate` (Alembic).
#CONTACTHOP_AUTO_CREATE_TABLES=true

# ── Channel adapters ────────────────────────────────────────────────────────
# "console" logs outbound traffic instead of sending — zero-credential dev mode.
#CONTACTHOP_SMS_ADAPTER=console          # console | twilio
#CONTACTHOP_EMAIL_ADAPTER=console        # none | console | smtp
#CONTACTHOP_VOICE_ADAPTER=console        # none | console | twilio

# Twilio (SMS + voice). Voice also requires PUBLIC_BASE_URL below.
#CONTACTHOP_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#CONTACTHOP_TWILIO_AUTH_TOKEN=your-auth-token
#CONTACTHOP_TWILIO_FROM_NUMBER=+15550001234

# SMTP email (host + from address required; username/password if your relay needs auth).
#CONTACTHOP_SMTP_HOST=smtp.example.com
#CONTACTHOP_SMTP_PORT=587
#CONTACTHOP_SMTP_USERNAME=assistant@example.com
#CONTACTHOP_SMTP_PASSWORD=app-password
#CONTACTHOP_SMTP_FROM_ADDRESS=assistant@example.com
#CONTACTHOP_SMTP_STARTTLS=true

# ── Webhooks & agent ────────────────────────────────────────────────────────
# Public URL of this deployment. Required for Twilio voice (Twilio must reach
# the call webhooks) and used to validate webhook signatures.
#CONTACTHOP_PUBLIC_BASE_URL=https://hop.example.com

# Where conversation events (inbound messages, follow-ups due) are pushed —
# point this at your agent's webhook (e.g. the SDK Agent app).
#CONTACTHOP_AGENT_WEBHOOK_URL=http://127.0.0.1:9000/

# Shared secret required (as X-ContactHop-Token) on the generic inbound email
# webhook, so only your provider bridge can post inbound mail.
#CONTACTHOP_EMAIL_INBOUND_TOKEN=change-me

# ── Security & abuse protection ─────────────────────────────────────────────
# Comma-separated Bearer tokens required on the /v1 management API
# (Authorization: Bearer <key>). Unset = open, for local development only.
# Webhooks are not affected — they use provider signatures / shared secrets.
#CONTACTHOP_API_KEYS=prod-key-1,prod-key-2

# Per-contact outbound cap across all channels, rolling hour; a hard backstop
# so a buggy agent can't flood a human. 0 = unlimited. Contacts can override
# via preferences: {"max_messages_per_hour": 10}
#CONTACTHOP_MAX_MESSAGES_PER_HOUR=30

# SMS consent keywords (STOP/START/HELP) are always handled — legally required.
# These configure the replies to HELP and START; STOP gets no app-level reply
# because the carrier sends the mandated confirmation.
#CONTACTHOP_SMS_HELP_REPLY=This number is operated by an AI assistant. Reply STOP to unsubscribe, START to resume.
#CONTACTHOP_SMS_OPT_IN_REPLY=You are resubscribed. Reply STOP to unsubscribe at any time.

# ── Follow-ups / escalation ─────────────────────────────────────────────────
# How often (seconds) the scheduler sweeps for due no-reply follow-ups.
#CONTACTHOP_FOLLOW_UP_POLL_INTERVAL=5.0

# ── Send windows (quiet hours) ──────────────────────────────────────────────
# Per-channel allowed hours, "HH:MM-HH:MM", evaluated in the contact's
# timezone (preferences["timezone"]) or DEFAULT_TIMEZONE below. Windows may
# wrap midnight (e.g. 21:00-08:00 = overnight only). Unset = always allowed.
# The gateway enforces these as a hard backstop: explicit sends on a closed
# channel are rejected, policy-routed sends hop to an open channel, and
# escalation suggestions skip closed channels. Exception: speech into an
# already-live voice call is always allowed.
#
# Example: business-hours texting and email, calls only mid-day —
#CONTACTHOP_SEND_WINDOW_SMS=08:00-17:00
#CONTACTHOP_SEND_WINDOW_EMAIL=08:00-17:00
#CONTACTHOP_SEND_WINDOW_VOICE=10:00-16:00
#
# Per-contact nuance lives on the contact record, overriding the above:
#   preferences = {"timezone": "America/Chicago",
#                  "send_windows": {"sms": "09:00-20:00", "voice": "12:00-13:00"}}
#
# Timezone used when a contact doesn't set one (IANA name):
#CONTACTHOP_DEFAULT_TIMEZONE=UTC
